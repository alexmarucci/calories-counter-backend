{
  "name": "openfoodfacts-search-api",
  "version": "1.0.0",
  "description": "Meilisearch-backed search and autocomplete API for Open Food Facts",
  "type": "module",
  "scripts": {
    "start": "node src/api.js",
    "index": "node src/indexer.js",
    "setup": "node src/setupIndex.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "meilisearch": "^0.49.0"
  },
  "jest": {
    "testMatch": ["**/tests/**/*.test.js"],
    "transform": {},
    "moduleFileExtensions": ["js", "mjs"]
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
